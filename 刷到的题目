function deepclone3(obj){
    if(typeof obj !== 'object' || typeof obj === null){
        return obj;
    }

    const res = Array.isArray(obj) ? []: {};
    for(let key in obj){
        if(obj.hasOwnProperty(key)){
            res = deepClone(res[key]);
        }
    }
    return res;
}




