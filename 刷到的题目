// 数组扁平化

function flattenArray(arr1){
    let newArr = [];
    arr1.forEach(item => {
        if(Array.isArray(item)){
            newArr.concat(flattenArray(item));
        }
        else newArr.push(item);
    })
    return newArr;
}


